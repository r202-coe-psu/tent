COUCHDB_USER=admin
COUCHDB_PASSWORD=password

# MongoDB public read-model (worker + FastAPI). Use service name `mongodb` in compose, not localhost.
# Host-run worker/backend: override with mongodb://localhost:27017/tentdb.
DATABASE_URI=mongodb://mongodb:27017/tentdb
# Required on staging — set real values in the server .env (do not commit secrets).
SECRET_KEY=change-me-in-staging
EXTERNAL_API_SECRET=change-me-in-staging

# Staging / production
PUBLIC_ORIGIN=http://localhost
PUBLIC_APP_TITLE=Tent
NGINX_PORT=80

# Nginx configuration
NGINX_HOST=127.0.0.1

# Configuration for exposing CouchDB to host (used when Nginx runs on host)
COUCHDB_BIND_IP=127.0.0.1
COUCHDB_PORT=5984

# Configuration for exposing SvelteKit frontend to host (used when Nginx runs on host)
FRONTEND_BIND_IP=127.0.0.1
FRONTEND_PORT=3000

# FastAPI bind (docker-compose.staging.no-nginx.yml — host nginx proxies to this)
FASTAPI_BIND_IP=127.0.0.1
FASTAPI_PORT=9000


# reCaptcha secret key for server-side verification. Required for production builds.
#! ตอนนี้ยังผูกกับเมลล์ของผู้พัฒนาอยู่ ถ้าจะใช้ต้องเปลี่ยนเป็นคีย์ที่ได้จาก Google reCaptcha ของคทีม
SECRET_RECAPTCHA_KEY=google_secret_key