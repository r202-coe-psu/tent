PUBLIC_APP_TITLE=Tent

# Public CouchDB base URL (NO credentials — this value is bundled into the
# browser). Used for cookie-authenticated session/sync requests.
PUBLIC_COUCHDB_URL=http://localhost:5984

# Vite dev proxy path — keeps CouchDB same-origin so session cookies work.
# Set to empty string to disable (e.g. production behind nginx).
PUBLIC_COUCH_PROXY=/couch