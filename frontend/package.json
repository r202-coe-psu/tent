{
	"name": "web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev --host 0.0.0.0",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "vite build --mode test && playwright test",
		"openapi": "openapi-typescript",
		"openapi:fetch": "mkdir -p src/libs/api-specs && curl -f http://localhost:9000/openapi.json -o src/libs/api-specs/fastapi.json",
		"openapi:fastapi": "openapi-typescript src/libs/api-specs/fastapi.json -o src/lib/api/openapi.d.ts",
		"openapi:update": "pnpm openapi:fetch && pnpm openapi:fastapi"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@internationalized/date": "^3.12.1",
		"@lucide/svelte": "^1.16.0",
		"@playwright/test": "^1.52.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.60.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/pouchdb-adapter-memory": "^6.1.6",
		"@types/pouchdb-browser": "^6.1.5",
		"@vitest/coverage-v8": "^4.1.8",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"formsnap": "^2.0.1",
		"globals": "^17.6.0",
		"happy-dom": "^20.10.1",
		"mode-watcher": "^1.1.0",
		"pouchdb-adapter-memory": "^9.0.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.2",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.55.7",
		"svelte-check": "^4.4.8",
		"svelte-sonner": "^1.1.1",
		"sveltekit-superforms": "^2.30.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.3",
		"vite": "^8.0.13",
		"vite-plugin-devtools-json": "^1.0.0",
		"vite-plugin-node-polyfills": "^0.28.0",
		"vitest": "^4.1.8",
		"zod": "^4.4.3"
	},
	"dependencies": {
		"@tanstack/svelte-query": "^6.1.29",
		"@tanstack/svelte-query-devtools": "^6.1.29",
		"events": "^3.3.0",
		"jsonwebtoken": "^9.0.3",
		"openapi-fetch": "^0.17.0",
		"openapi-typescript": "^7.13.0",
		"pouchdb-browser": "^9.0.0"
	}
}
